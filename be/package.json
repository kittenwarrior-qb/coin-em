{
  "name": "emcoin-backend",
  "version": "1.0.0",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:bot": "cross-env DISABLE_RATE_LIMIT=true tsx tests/bot/bot-simulation.ts",
    "test:bot:debug": "cross-env DISABLE_RATE_LIMIT=true LOG_LEVEL=DEBUG tsx tests/bot/bot-simulation.ts",
    "test:advanced": "vitest run tests/advanced",
    "test:concurrent": "vitest run tests/advanced/concurrent-actions.test.ts",
    "test:persistence": "vitest run tests/advanced/persistence-failure.test.ts",
    "test:load": "vitest run tests/advanced/load-stress.test.ts --pool=forks --poolOptions.forks.singleFork",
    "test:reconnect": "vitest run tests/advanced/reconnect-network.test.ts"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^2.1.8",
    "cross-env": "^7.0.3",
    "socket.io-client": "^4.7.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^2.1.8"
  }
}
