# Build stage
FROM node:20-alpine AS builder

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source code
COPY . .

# Build for production
RUN npm run build

# Production stage - minimal image
FROM alpine:latest

WORKDIR /var/www/html

# Copy built files
COPY --from=builder /app/dist .

# No server needed, Caddy will serve the static files
